{
  "name": "Player",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Player name or gamertag"
    },
    "tier": {
      "type": "string",
      "enum": [
        "HT1",
        "LT1",
        "HT2",
        "LT2",
        "HT3",
        "LT3",
        "HT4",
        "LT4",
        "HT5",
        "LT5"
      ],
      "description": "Current tier ranking"
    },
    "mode": {
      "type": "string",
      "description": "Game mode this ranking applies to"
    },
    "position": {
      "type": "number",
      "description": "Position within the tier (for ordering)"
    },
    "image_url": {
      "type": "string",
      "description": "Player avatar or image URL"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the player"
    }
  },
  "required": [
    "name",
    "tier",
    "mode"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}